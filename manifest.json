{
  "manifest_version": 3,
  "name": "Showdown Battle Test Bot",
  "version": "0.2.0",
  "description": "Automates simple move/switch choices in your own unrated Pokemon Showdown battles, for learning and bug testing only.",
  "permissions": ["storage", "scripting", "tabs"],
  "host_permissions": ["https://play.pokemonshowdown.com/*"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://play.pokemonshowdown.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Showdown Test Bot"
  }
}
